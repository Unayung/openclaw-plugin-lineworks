{
  "name": "@unayung/lineworks",
  "version": "0.1.0-poc.0",
  "description": "OpenClaw LINE WORKS channel plugin (PoC)",
  "type": "module",
  "main": "./index.ts",
  "license": "MIT",
  "dependencies": {
    "jose": "^5.10.0"
  },
  "peerDependencies": {
    "openclaw": "^2026.4.15"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.4",
    "express": "^5.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "files": [
    "api.ts",
    "index.ts",
    "setup-api.ts",
    "setup-entry.ts",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "lineworks",
      "label": "LINE WORKS",
      "selectionLabel": "LINE WORKS (Works Mobile)",
      "detailLabel": "LINE WORKS Bot",
      "docsPath": "/channels/lineworks",
      "docsLabel": "lineworks",
      "blurb": "LINE WORKS (Works Mobile) enterprise bot channel.",
      "aliases": [
        "worksmobile",
        "works"
      ],
      "order": 76,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@unayung/lineworks",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    }
  }
}
